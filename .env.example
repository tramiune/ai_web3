# Kling chính chủ — bot_kling (Motion Control 2.6 / 720p / Matches Video)
# Mỗi nick = 1 Chrome profile (login tay lần đầu)
KLING_ACCOUNTS=nick1,nick2
# KLING_ACCOUNT_PATHS=nick1:D:\profiles\kling1,nick2:D:\profiles\kling2
KLING_MODEL_VERSION=2.6
KLING_RESOLUTION=720p
KLING_CHARACTER_ORIENTATION=video
# Giá: 0.6 coin/giây · làm tròn lên giây · tối đa 30s
KLING_COINS_PER_SEC=0.6
COIN_VND_RATE=1000
KLING_MIN_VIDEO_SEC=3
KLING_MAX_VIDEO_SEC=30
KLING_MAX_CONCURRENT=1
KLING_LOGIN_TIMEOUT_SEC=300
KLING_POLL_TIMEOUT_SEC=900
KLING_MIN_RENDER_SEC=180
# KLING_CDP_URL=http://127.0.0.1:9222
# KLING_HEADLESS=0

# Poll bot
BOT_MIN_RENDER_SEC=180
BOT_POLL_ACTIVE_SEC=90
BOT_POLL_IDLE_SEC=300
SESSION_ERROR_BACKOFF_SEC=300

# R2 upload kết quả (xiaoyang direct worker)
XIAOYANG_DIRECT_WORKER_URL=https://xiaoyang-direct-media.traderfinn0312.workers.dev

# Telegram (Kaling bot noti)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
