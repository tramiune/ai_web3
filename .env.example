# Aidancing Pure HTTP (fallback khi XiaoYang đầy/fail)
AIDANCING_COOKIE=JSESSIONID=your_session_here

# XiaoYang web session (multi-nick, max 4 đơn/nick)
XIAOYANG_ACCOUNTS=motionaistudio3@gmail.com:password
XIAOYANG_MAX_CONCURRENT=4
XIAOYANG_ENHANCE_4K=1
XIAOYANG_DIRECT_WORKER_URL=https://xiaoyang-direct-media.traderfinn0312.workers.dev
# Bot tự chọn: fast (124/125)→motion_v26, turbo (117)→motion_v30
XIAOYANG_MODAL_KEY=motion_v26
XIAOYANG_OPTION_KEY=default
XIAOYANG_MOTION_ORIENTATION=video
XIAOYANG_MIN_CREDITS_FAST=80
XIAOYANG_MIN_CREDITS_TURBO=220
XIAOYANG_CREDITS_CACHE_SEC=120

# Poll sau N giây từ submittedAt (300 = 5 phút)
BOT_MIN_RENDER_SEC=300
BOT_POLL_ACTIVE_SEC=90
BOT_POLL_IDLE_SEC=300

# VideoAiEasy (Engine C) — email:password cách nhau dấu phẩy
VIDEOAIEASY_ACCOUNTS=kaling@gmail.com:your_password_here
VIDEOAIEASY_MAX_CONCURRENT=50
VIDEOAIEASY_SLOT_RETRY_SEC=20

# RoboNeo (model 127 / Chất lượng)
ROBONEO_PROXY_KEY=
ROBONEO_PROXY_PROVINCE_ID=3
ROBONEO_ALLOW_DIRECT=1
ROBONEO_SURFACE=team_studio
ROBONEO_QUALITY_MODEL=v26
ROBONEO_MOTION_MODE=std
ROBONEO_CREDITS_PER_15S=115
PROXY_ROTATE_COOLDOWN_SEC=60
PROXY_ACCOUNTS_PER_IP=2
ROBONEO_MAX_CONCURRENT=2
ROBONEO_MIN_RENDER_SEC=300
ROBONEO_MIN_REUSE_VIDEO_SEC=5
ROBONEO_CREDIT_SYNC_TTL_SEC=180
ROBONEO_STARTUP_SYNC_MAX=15
ROBONEO_PROMPT=Follow the reference motion naturally
# Pool chung MotionAI + Kaling (VPS bắt buộc):
ROBONEO_POOL_FILE=/root/shared/roboneo/account_pool.json

# Huanaihub — mua nick RoboNeo tự động (0 = tắt, chỉ dùng nick trong pool)
ROBONEO_AUTO_BUY=0
HUANAIHUB_USERNAME=
HUANAIHUB_PASSWORD=
HUANAIHUB_PRODUCT_ID=138

# Telegram (Kaling bot noti)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Tùy chọn
XIAOYANG_NO_PROXY=1
XIAOYANG_API_RETRIES=5
XIAOYANG_API_RETRY_SEC=8
